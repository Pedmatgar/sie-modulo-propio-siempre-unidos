<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- List view -->
    <record id="view_sie_member_list" model="ir.ui.view">
        <field name="name">sie.member.list</field>
        <field name="model">sie.member</field>
        <field name="arch" type="xml">
            <list string="Miembros SIE" decoration-muted="state == 'inactive'">
                <field name="code"/>
                <field name="name"/>
                <field name="email"/>
                <field name="phone"/>
                <field name="date_join"/>
                <field name="state"/>
            </list>
        </field>
    </record>

    <!-- Form view -->
    <record id="view_sie_member_form" model="ir.ui.view">
        <field name="name">sie.member.form</field>
        <field name="model">sie.member</field>
        <field name="arch" type="xml">
            <form string="Miembro SIE">
                <header>
                    <button name="action_activate" string="Activar"
                            type="object" class="oe_highlight"
                            invisible="state != 'draft'"/>
                    <button name="action_deactivate" string="Desactivar"
                            type="object"
                            invisible="state != 'active'"/>
                    <button name="action_reset_draft" string="Restablecer a Borrador"
                            type="object"
                            invisible="state == 'draft'"/>
                    <field name="state" widget="statusbar"
                           statusbar_visible="draft,active,inactive"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <label for="name" string="Nombre del Miembro"/>
                        <h1>
                            <field name="name" placeholder="Nombre completo..."/>
                        </h1>
                    </div>
                    <group>
                        <group string="Información General">
                            <field name="code"/>
                            <field name="email"/>
                            <field name="phone"/>
                            <field name="date_join"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Notas">
                            <field name="notes" placeholder="Agregar notas aquí..."/>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Search view -->
    <record id="view_sie_member_search" model="ir.ui.view">
        <field name="name">sie.member.search</field>
        <field name="model">sie.member</field>
        <field name="arch" type="xml">
            <search string="Buscar Miembros">
                <field name="name" string="Nombre"/>
                <field name="code" string="Código"/>
                <field name="email" string="Correo"/>
                <separator/>
                <filter string="Activos" name="active_members"
                        domain="[('state', '=', 'active')]"/>
                <filter string="Borradores" name="draft_members"
                        domain="[('state', '=', 'draft')]"/>
                <filter string="Inactivos" name="inactive_members"
                        domain="[('state', '=', 'inactive')]"/>
                <group expand="0" string="Agrupar por">
                    <filter string="Estado" name="group_by_state"
                            context="{'group_by': 'state'}"/>
                    <filter string="Fecha de Ingreso" name="group_by_date"
                            context="{'group_by': 'date_join'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- Action -->
    <record id="action_sie_member" model="ir.actions.act_window">
        <field name="name">Miembros</field>
        <field name="res_model">sie.member</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_sie_member_search"/>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                ¡Crea tu primer miembro!
            </p>
            <p>
                Registra y gestiona los miembros del sistema SIE.
            </p>
        </field>
    </record>

</odoo>
